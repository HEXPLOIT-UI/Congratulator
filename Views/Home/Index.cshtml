@page
@using Congratulator.Models
@model BirthdayModel
<!DOCTYPE html>
<html>
<head>
    <title>Поздравлятор</title>
    <script src="~/js/jQuery/jquery.min.js"></script>
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/modal.css" rel="stylesheet" />
</head>
<body>
    <button type="button" onclick="openAddMenu()" id="openModalBtn">Добавить</button>
    <button type="button" onclick="displayAllBirthdays()" id="switchBirthdayShowType">Показать все дни рождения</button>
    <div id="birthdayModal" class="modal">
        <div class="modal-content">
            <span onclick="closeAddMenu()" class="close">&times;</span>
            <form id="birthdayForm">
                <label for="FullName">Имя</label>
                <input type="text" id="fullName" name="FullName" required minlength="3" maxlength="50">

                <label for="BirthdayDate">Дата</label>
                <input type="date" id="birthdayDate" name="BirthdayDate" required>

                <label for="ProfileImage">Загрузить изображение</label>
                <input type="file" id="profileImage" name="ProfileImage">

                <button type="button" onclick="submitBirthdayForm()">Добавить</button>
            </form>
        </div>
    </div>
    <h1 id="showTypeText">Список ближайших дней рождения</h1>
    <button id="editButton">Редактировать</button>
    <button id="saveButton" style="display: none;">Завершить</button>
    <table id="sortTable">
        <thead>
            <tr>
                <th onclick="sortTable(0)">Фото</th>
                <th onclick="sortTable(1)">Имя</th>
                <th onclick="sortTable(2)">Дата дня рождения</th>
            </tr>
        </thead>
        <tbody>
            
        </tbody>
    </table>

    <script src="~/js/site.js"></script>
    <script src="~/js/modal.js"></script>
</body>
</html>
